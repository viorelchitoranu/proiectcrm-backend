<?xml version="1.0" encoding="UTF-8"?>

<!--
    Configurare Logback pentru ProiectCRM.

    Profiluri:
      "dev"  → console cu culori, fara fisiere
      "prod" → fisiere cu rotatie zilnica, fara console

    Fisiere produse in productie (la calea ${logging.file.path}):
      app.log    → toate evenimentele INFO+ (30 zile, max 1 GB)
      error.log  → WARN si ERROR (90 zile, max 500 MB)

    Format log exemplu:
      2026-03-15 14:32:07.418 INFO  [req:a3f9c2d1] [user:ion***@***.ro] [POST /api/admin/children/5/deactivate]
      c.s.p.service.AdminChildServiceImpl - DEACTIVATE_CHILD child=5 slotsReleased=2

    MDC keys (injectate automat de MdcFilter.java per fiecare request HTTP):
      requestId  → 8 caractere UUID — coreleaza toate logurile unui request
      userEmail  → email mascat GDPR (ion***@***.ro) sau "anon" daca neautentificat
      httpMethod → GET / POST / PATCH / DELETE
      httpPath   → /api/admin/children/5/deactivate

    ATENTIE: MDC.clear() in MdcFilter.finally() este OBLIGATORIU.
    Fara clear(), un thread refolosit din pool ar purta MDC-ul request-ului anterior.
-->
<configuration>

    <!-- Pattern partajat intre console (dev) si fisier (prod) -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [req:%X{requestId:-?}] [user:%X{userEmail:-anon}] [%X{httpMethod:- }%X{httpPath:-}] %logger{36} - %msg%n"/>

    <!-- ===========================================================
         PROFIL DEV: console colorata
         =========================================================== -->
    <springProfile name="dev">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <!-- %highlight coloreaza nivelul cu ANSI: INFO=alb, WARN=galben, ERROR=rosu -->
                <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [req:%X{requestId:-?}] [%X{userEmail:-anon}] %logger{30} - %msg%n</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <!-- Reducem zgomotul framework-urilor in dev -->
        <logger name="org.springframework"          level="WARN"/>
        <logger name="org.hibernate"                level="WARN"/>
        <logger name="com.zaxxer.hikari"            level="WARN"/>
    </springProfile>

    <!-- ===========================================================
         PROFIL PROD: fisiere cu rotatie, fara console
         =========================================================== -->
    <springProfile name="prod">

        <!-- app.log: toate evenimentele INFO+ -->
        <appender name="FILE_ALL" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${logging.file.path}/app.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>${logging.file.path}/app.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
                <maxHistory>30</maxHistory>
                <totalSizeCap>1GB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <!-- error.log: DOAR WARN si ERROR, pentru monitorizare alertare rapida -->
        <appender name="FILE_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${logging.file.path}/error.log</file>
            <!-- Ignora INFO, accepta doar WARN si ERROR -->
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>WARN</level>
            </filter>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>${logging.file.path}/error.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
                <maxHistory>90</maxHistory>
                <totalSizeCap>500MB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="FILE_ALL"/>
            <appender-ref ref="FILE_ERROR"/>
        </root>

        <logger name="org.springframework"          level="WARN"/>
        <logger name="org.hibernate"                level="WARN"/>
        <logger name="com.zaxxer.hikari"            level="WARN"/>
        <logger name="org.springframework.security" level="WARN"/>
    </springProfile>

</configuration>
